PORT=8000
HOST=127.0.0.1
PROJECT_NAME="Developer Portfolio API"

# CORS: через запятую указать допустимые источники (или "*" для всех)
CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173,https://your-frontend.vercel.app"

# Настройки почты (для Gmail требуется сгенерировать "Пароль приложения")
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your_email@gmail.com"
SMTP_PASSWORD="your_gmail_app_password"
EMAIL_FROM="your_email@gmail.com"
EMAIL_TO_OWNER="your_email@gmail.com"

# Настройки интеграции с ИИ (Groq API)
AI_BASE_URL="https://api.groq.com/openai/v1"
AI_API_KEY="your_groq_api_key"
AI_MODEL="llama-3.1-8b-instant"